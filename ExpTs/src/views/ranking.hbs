<div class="card-box">
  <h1>🏆 Ranking — Top 10</h1>

  <table class="table table-dark table-striped ranking-table">
    <thead>
      <tr>
        <th>Posição</th>
        <th>Jogador</th>
        <th>Pontuação</th>
      </tr>
    </thead>
    <tbody>
      {{#each topScores}}
        <tr>
          <td>{{add @index 1}}º</td>
          <td>{{this.userName}}</td>
          <td>{{this.score}}</td>
        </tr>
      {{else}}
        <tr>
          <td colspan="3">Nenhuma pontuação registrada ainda. Seja o primeiro a jogar!</td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</div>

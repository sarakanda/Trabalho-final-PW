<link rel="stylesheet" href="/css/game.css" />

<div id="kage-run-root">

  <!-- MENU INICIAL -->
  <div id="menu">
    <div id="menu-box">
      <h1 id="menu-title">影 KAGE RUN</h1>
      <p id="menu-subtitle">O ninja não para. Você para?</p>

      <div id="difficulty-select">
        <p>Escolha a dificuldade:</p>
        <div id="difficulty-buttons">
          <button class="diff-btn" data-diff="easy">🌸 Fácil</button>
          <button class="diff-btn selected" data-diff="medium">⚔ Médio</button>
          <button class="diff-btn" data-diff="hard">💀 Difícil</button>
        </div>
      </div>

      <button id="btn-start">Iniciar</button>

      <div id="records-box">
        <p id="records-title">🏆 Confira o <a href="/ranking">ranking completo</a> após jogar!</p>
      </div>
    </div>
  </div>

  <!-- TELA DO JOGO -->
  <div id="game-screen" class="hidden">
    <div id="world">
      <div id="bg-far"></div>
      <div id="bg-near"></div>
      <div id="ground"></div>
    </div>

    <!-- HUD -->
    <div id="hud">
      <span id="hud-score">Pontos: 0</span>
      <span id="hud-lives">❤ ❤ ❤</span>
      <span id="hud-powerup"></span>
    </div>

    <!-- PAUSA -->
    <div id="pause-overlay" class="hidden">
      <div id="pause-box">
        <p>⏸ Pausado</p>
        <button id="btn-resume">Continuar</button>
        <button id="btn-menu-pause">Menu</button>
      </div>
    </div>
  </div>

  <!-- TELA DE GAME OVER -->
  <div id="gameover-screen" class="hidden">
    <div id="gameover-box">
      <h2>Game Over</h2>
      <p id="gameover-score"></p>
      <p id="gameover-record"></p>
      <button id="btn-restart">Jogar de novo</button>
      <button id="btn-menu-over">Menu</button>
    </div>
  </div>

</div>

<script type="module" src="/js/game.js"></script>
